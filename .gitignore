# --- IDE & Notebooks ---
.idea/
.ipynb_checkpoints/
__pycache__/

# --- Python Virtual Environment ---
venv/
.venv/

# --- Project Settings & Secrets ---
# CRITICAL: Never commit .env files containing API keys or passwords
.env

# --- Resources & Large Data ---
simplified-CBIS-DDSM/
images/
*.jpeg
*.jpg
*.gif
*.png
*.csv
*.zip
*.pdf

# --- Exceptions (Whitelisting) ---
# We use the exclamation mark (!) to NOT ignore (allow) specific files,
# even if their extensions are excluded above.

# Keep EDA reports
!data_analysis/eda/*.csv
!data_analysis/eda/*.png

# Keep documentation files (regardless of folder depth)
!documentation/**/*.md
!documentation/**/*.png
!documentation/**/*.csv
!documentation/**/*.xlsx